{
  "name": "innovation-engineering",
  "type": "module",
  "version": "0.1.44",
  "private": "true",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "biome format --write ./src",
    "lint:md": "markdownlint-cli2 '**/*.{md,mdx}' '#node_modules'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mjs,astro,css}": [
      "biome check --write"
    ],
    "*.{md,mdx}": [
      "markdownlint-cli2"
    ]
  },
  "dependencies": {
    "@astrojs/starlight": "0.41.3",
    "@fontsource/public-sans": "5.3.0",
    "astro": "7.1.1",
    "sharp": "0.35.3",
    "starlight-links-validator": "0.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "markdownlint-cli2": "0.23.1"
  }
}
